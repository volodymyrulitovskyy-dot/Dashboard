# Core app
DATABASE_URL="file:./dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-strong-random-secret"
WORKFLOW_API_SECRET="replace-with-long-random-secret"
WORKFLOW_TEAM_IDS="team-finance-ops,team-corporate-close"
WORKFLOW_ALLOWED_IPS=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SECRET_KEY=""

# Google OAuth SSO
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft Entra ID (Azure AD) SSO
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"
LOCAL_ADMIN_EMAIL="admin@example.com"
# Optional plain fallback for local-only use
LOCAL_ADMIN_PASSWORD="change-me-for-local-dev"
# Preferred: SHA-256 hash of local admin password
LOCAL_ADMIN_PASSWORD_SHA256=""

# Optional: comma-separated admin emails with elevated RBAC roles
APP_ADMIN_EMAILS=""
# Optional: restrict sign-in to a single email domain, e.g. company.com
APP_ALLOWED_EMAIL_DOMAIN=""
# Optional: comma-separated additional origins for mutation request validation
APP_ALLOWED_ORIGINS=""

# Ramp OAuth2 client credentials
RAMP_CLIENT_ID=""
RAMP_CLIENT_SECRET=""
RAMP_SCOPES="bills:read vendors:read transactions:read receipts:read reimbursements:read users:read departments:read entities:read"

# ADP payroll API
ADP_API_BASE_URL=""
ADP_API_TOKEN=""
ADP_CLIENT_ID=""
ADP_CLIENT_SECRET=""
ADP_TOKEN_ENDPOINT="/oauth2/v1/token"
ADP_SCOPES=""
ADP_PAYROLL_ENDPOINT="/api/payroll/v1/gross-wages"

# NetSuite OAuth 2.0 M2M
NETSUITE_ACCOUNT_ID=""
NETSUITE_CLIENT_ID=""
NETSUITE_CERTIFICATE_ID=""
NETSUITE_PRIVATE_KEY_PEM=""
NETSUITE_SCOPES="rest_webservices"
NETSUITE_TOTALS_ENDPOINT=""
NETSUITE_AR_TOTAL_QUERY=""
NETSUITE_AP_TOTAL_QUERY=""
NETSUITE_GL_TOTAL_QUERY=""
NETSUITE_LABOR_JE_ENDPOINT="/services/rest/record/v1/journalEntry"
NETSUITE_LABOR_DEBIT_ACCOUNT_ID=""
NETSUITE_LABOR_CREDIT_ACCOUNT_ID=""
NETSUITE_LABOR_SUBSIDIARY_ID=""
NETSUITE_LABOR_CURRENCY_ID=""
NETSUITE_LABOR_APPROVAL_STATUS=""
NETSUITE_LABOR_PROJECT_FIELD_ID="job"
NETSUITE_LABOR_PROJECT_ID_MAP="{}"
NETSUITE_LABOR_DEPARTMENT_ID=""
NETSUITE_LABOR_CLASS_ID=""
NETSUITE_LABOR_LOCATION_ID=""
NETSUITE_LABOR_MEMO_PREFIX="Labor Allocation"

# Unanet API reconciliation
UNANET_API_BASE_URL=""
UNANET_API_TOKEN=""
UNANET_TOKEN_ENDPOINT="/oauth/token"
UNANET_TOTALS_ENDPOINT="/api/v1/finance/reconciliation/totals"
UNANET_TIMESHEETS_ENDPOINT="/api/v1/timesheets/hours-by-project"
UNANET_CLIENT_ID=""
UNANET_CLIENT_SECRET=""
UNANET_SCOPES=""

# Optional fallback: Unanet export ingestion
UNANET_IMPORT_DIR="./data/unanet"
